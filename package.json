{
  "name": "natalia-website",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' vite build",
    "preview": "vite preview",
    "start": "NODE_OPTIONS='--max-old-space-size=4096' node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^3.0.0",
    "@sveltejs/kit": "2.21.1",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-basic-ssl": "^1.0.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.35.1",
    "prettier": "^3.1.1",
    "prettier-plugin-svelte": "^3.1.2",
    "svelte": "^4.2.7",
    "svelte-check": "^3.6.0",
    "terser": "^5.40.0",
    "tslib": "^2.4.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.3"
  },
  "type": "module",
  "dependencies": {
    "@portabletext/svelte": "^2.0.0",
    "@sanity/client": "^6.12.0",
    "@sanity/image-url": "^1.0.2",
    "dotenv": "^16.5.0",
    "googleapis": "^100.0.0",
    "nodemailer": "^6.10.1",
    "normalize.css": "^8.0.1",
    "svelte-intersection-observer": "^0.10.0",
    "svelte-meta-tags": "^2.6.3",
    "svelte-portal": "^2.1.2",
    "swiper": "^11.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
